{
  "name": "official-document-manager",
  "version": "1.0.0",
  "description": "Node.js based official document management web app using JSON file storage.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "build:exe": "pkg launcher/official-document-launcher.js --targets node18-win-x64 --output 공문관리.exe",
    "mcp": "node server/mcp/kordocMcpServer.js",
    "mcp:kordoc": "node server/mcp/kordocMcpServer.js",
    "mcp:documents": "node server/mcp/officialDocumentMcpServer.js",
    "mcp:gmail": "node server/mcp/gmailReminderMcpServer.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.5",
    "dotenv": "^16.4.7",
    "express": "^4.18.3",
    "kordoc": "^2.9.1",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.104.0",
    "pdfjs-dist": "^6.0.227"
  },
  "pkg": {
    "assets": [
      "public/**/*",
      "persona/examples/**/*",
      "node_modules/kordoc/dist/**/*",
      "node_modules/pdfjs-dist/**/*"
    ],
    "scripts": [
      "server/**/*.js",
      "launcher/**/*.js"
    ]
  }
}
